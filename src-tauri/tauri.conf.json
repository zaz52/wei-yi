{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "唯一",
  "version": "2.2.11",
  "identifier": "com.zaz52.weiyi",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "唯一",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https: http:; img-src 'self' asset: https://asset.localhost; media-src 'self' asset: https://asset.localhost; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "../NvwaSKILL/**/*": "NvwaSKILL/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcwN0NFN0EzRUJERERDRTgKUldUbzNOM3JvK2Q4Y005eDcrenB4ZlNwVmZpMFJ4M0dLSERidlROZmtLcG9jWjZEdTlBK3J4TXIK",
      "endpoints": [
        "https://github.com/zaz52/wei-yi/releases/latest/download/latest.json"
      ]
    }
  }
}
